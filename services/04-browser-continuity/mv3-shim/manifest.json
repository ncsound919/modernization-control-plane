{
  "manifest_version": 3,
  "name": "MCP Browser Continuity Extension",
  "version": "1.0.0",
  "description": "Modernization Control Plane — MV3 extension template providing XSLT polyfill and legacy API shims for enterprise portals.",
  "author": "MCP Platform Team",

  "permissions": [
    "storage",
    "scripting",
    "alarms"
  ],

  "host_permissions": [
    "https://*.enterprise.internal/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "MCP Browser Continuity"
  },

  "content_scripts": [
    {
      "matches": ["https://*.enterprise.internal/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "xslt-polyfill.wasm",
        "xslt-polyfill-sdk.js",
        "mv3-shim-sdk.js"
      ],
      "matches": ["https://*.enterprise.internal/*"]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
